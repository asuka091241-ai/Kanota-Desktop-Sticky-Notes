{
  "name": "kanota",
  "version": "1.0.0",
  "description": "Kanota 桌面看板便签 - 拖拽任务管理 + 桌面便签 + 主题切换",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win portable && npx rcedit release\\win-unpacked\\Kanota.exe --set-icon icon.ico"
  },
  "build": {
    "appId": "com.kanota.app",
    "productName": "Kanota",
    "directories": {
      "output": "release"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-sticky.js",
      "sticky.html",
      "index.html",
      "package.json",
      "icon.png",
      "icon.ico"
    ],
    "win": {
      "target": "portable",
      "icon": "icon.ico"
    },
    "portable": {
      "artifactName": "Kanota.exe"
    }
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8",
    "png-to-ico": "^3.0.1",
    "rcedit": "^5.0.1",
    "sharp": "^0.35.2",
    "to-ico": "^1.1.5"
  }
}
